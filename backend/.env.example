APP_ENV=production
API_SECRET_KEY=change-me-to-random-64-char-string

DATABASE_URL=postgresql+psycopg2://gumucroyal:gumucroyal@gumucroyal_database:5432/gumucroyal

CORS_ORIGINS=["https://gumucroyal.store"]

# Admin dashboard — /admin on frontend
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# Google Sheets webhook (Apps Script deployment URL — no secret in URL)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
GOOGLE_SHEETS_WEBHOOK_SECRET=change-me-to-random-webhook-secret

# Optional — shared rate limits across API replicas (recommended in production)
REDIS_URL=redis://redis:6379/0

META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=

SNAP_PIXEL_ID=
SNAP_CAPI_ACCESS_TOKEN=

UPSELL_PRICE_MAD=69
ADD_PIECE_PRICE_MAD=69
